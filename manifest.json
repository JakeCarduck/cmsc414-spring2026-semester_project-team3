{
    "manifest_version": 3,
    "name": "Malvertising Prevention Extension",
    "short_name": "Malvertising Prevention",
    "version": "0.1.0",
    "description": "An extension to prevent malvertising on the web.",
    "icons": {
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_title": "Open Extension Menu",
        "default_popup": "popup/action-menu.html"
    },
    "background": {
        "service_worker": "scripts/service-worker.js"
    },
    "permissions": [
        "contextMenus",
        "scripting"
    ],
    "host_permissions": ["<all_urls>"],
    "web_accessible_resources": [{
        "resources": ["data/ad_websites.txt"],
        "matches": ["<all_urls>"]
    }]

    
}